# ============================================================
# MALDERON CREATOR — Variables de entorno
# ============================================================
# Copia este archivo a .env y completa tus API keys:
#   cp .env.example .env
# ============================================================

# 🔀 OpenRouter (OBLIGATORIO — scripts, prompts, división de escenas)
# Regístrate en https://openrouter.ai y agrega saldo
OPENROUTER_API_KEY=sk-or-v1-...

# 🎙️ GenAIPro TTS (OBLIGATORIO — voz + subtítulos SRT)
# Obtén tu key en https://genaipro.vn
GENAIPRO_API_KEY=eyJh...

# 🖼️ Pollinations (OBLIGATORIO — generación de imágenes)
# Obtén tu key en https://pollinations.ai
POLLINATIONS_API_KEY=sk_...

# 🎬 NCA Toolkit (OBLIGATORIO — renderizado de video final)
# Instala NCA Toolkit localmente: https://github.com/NCA-AI/NCA-Toolkit
NCA_TOOLKIT_URL=http://localhost:8090
NCA_API_KEY=

# ── Opcionales ────────────────────────────────────────────

# OpenAI (opcional — TTS alternativo + Whisper para transcripción)
OPENAI_API_KEY=sk-proj-...

# Anthropic (opcional — ya no es el proveedor principal)
ANTHROPIC_API_KEY=sk-ant-...

# Google (opcional — solo si quieres usar Imagen 3 directamente)
GOOGLE_API_KEY=AIzaSy...

# WaveSpeed (opcional — animación imagen-a-video i2v)
WAVESPEED_API_KEY=...

# Stock media (opcional)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── Configuración de runtime ──────────────────────────────

# Proveedor de imágenes: "pollinations" | "wavespeed"
IMAGE_PROVIDER=pollinations

# Hilos paralelos para procesar escenas
MAX_WORKERS=3

# Directorio de salida de proyectos
PROJECTS_DIR=./projects
